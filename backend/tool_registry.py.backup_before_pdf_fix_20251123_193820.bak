def get_distance_and_route_tool(origin: str, destination: str, mode: str = "driving") -> Dict[str, str]:
    """
    Berechnet die Entfernung und Reisezeit zwischen zwei Orten.
    Modi: 'driving' (Auto), 'walking' (Zu Fuß), 'cycling' (Fahrrad).
    Nutzt OpenStreetMap Daten (Nominatim & OSRM).
    """
    geolocator = Nominatim(user_agent="janus_projekt_distance_tool")
    try:
        # 1. Koordinaten ermitteln
        loc_a = geolocator.geocode(origin)
        loc_b = geolocator.geocode(destination)

        if not loc_a:
            return {"status": "error", "message": f"Ort '{origin}' konnte nicht gefunden werden."}
        if not loc_b:
            return {"status": "error", "message": f"Ort '{destination}' konnte nicht gefunden werden."}

        # 2. OSRM API abfragen
        # Mapping der LLM-Begriffe auf OSRM-API-Endpunkte ('bike', 'foot', 'driving')
        osrm_mode = "driving"  # Standard
        if mode == "walking": 
            osrm_mode = "foot"
        elif mode == "cycling": 
            osrm_mode = "bike"
        
        # URL Aufbau
        url = f"http://router.project-osrm.org/route/v1/{osrm_mode}/{loc_a.longitude},{loc_a.latitude};{loc_b.longitude},{loc_b.latitude}?overview=false"
        
        response = requests.get(url, timeout=10)
        response.raise_for_status()
        data = response.json()

        if data.get("code") != "Ok" or not data.get("routes"):
             return {"status": "error", "message": "Keine Route gefunden."}

        route = data["routes"][0]
        distance_km = route["distance"] / 1000
        duration_seconds = route["duration"]
        
        # Formatierung der Dauer
        hours = int(duration_seconds // 3600)
        minutes = int((duration_seconds % 3600) // 60)
        
        duration_str = ""
        if hours > 0: duration_str += f"{hours} Std. "
        if minutes > 0: duration_str += f"{minutes} Min."
        if not duration_str: duration_str = "weniger als 1 Minute"

        output = (
            f"Route von {origin} nach {destination} ({mode}):\n"
            f"Entfernung: {distance_km:.1f} km\n"
            f"Geschätzte Dauer: {duration_str}"
        )
        
        logger.info(f"Route berechnet: {output}")
        return {"status": "success", "output": output}

    except Exception as e:
        logger.error(f"Fehler im Distance-Tool: {e}", exc_info=True)
        return {"status": "error", "message": f"Fehler bei der Routenberechnung: {e}"}

# --- NEUE SAUBERE SCHEMAS (ADD-ON PATTERN) ---
# Wir definieren diese LOKAL, um die Core-Schemas in backend/data/schemas.py nicht zu ändern.
# Diese hier haben KEINE Beispiele, um Gemini-Halluzinationen (Köln/Rom) zu stoppen.

class CleanGetDistanceArgs(BaseModel):
    origin: str = Field(..., description="Der Startort der Route. Extrahiere diesen exakt aus der Anfrage.")
    destination: str = Field(..., description="Der Zielort der Route. Extrahiere diesen exakt aus der Anfrage.")
    mode: str = Field("driving", description="Der Fortbewegungsmodus: 'driving' (Auto), 'walking' (Zu Fuß), 'cycling' (Fahrrad).")

class CleanGetWeatherFromApiToolArgs(BaseModel):
    city: str = Field(..., description="Die Stadt für die Wettervorhersage. Nenne NUR die Stadt aus der Anfrage.")
    date_str: Optional[str] = Field(None, description="Das Datum (z.B. 'heute', 'morgen', 'Samstag').")

class CleanGetWikipediaSummaryArgs(BaseModel):
    query: str = Field(..., description="Der genaue Suchbegriff für Wikipedia (z.B. 'Eiffelturm', 'Thermodynamik').")
    lang: str = Field("de", description="Sprachcode, meist 'de'.")

# --- NEU: Sauberes News-Schema gegen Überoptimierung ---
class CleanGetLatestNewsRssToolArgs(BaseModel):
    source: str = Field(..., description="Die Quelle. Wähle exakt: 'spiegel', 'gamestar', 'tagesschau', 'zeit', 'heise', 'reuters' oder 'bbc'.")
    query: Optional[str] = Field(None, description="Optional: Ein spezifisches Thema zur Filterung. Nutze hierfür explizite Themen vom Benutzer ODER bekannte Interessen aus dem Core Memory (z.B. 'Nintendo Switch', 'BVB').")

# --- Registrierung aller Tools ---

def register_all_tools():
    """Registriert alle verfügbaren Tools im System."""
    # Allgemeine Tools
    
    # 1. DISTANZ: Härtere Formulierung gegen Halluzinationen
    register_tool(Tool(
        func=get_distance_and_route_tool, 
        args_schema=CleanGetDistanceArgs,
        description=(
            "Berechnet die exakte Entfernung, Route und Fahrzeit zwischen zwei Orten. "
            "WARNUNG: Nutze NUR die Orte, die der Benutzer im Chat genannt hat. "
            "Erfinde NIEMALS Start oder Ziel (wie 'Rom' oder 'Köln'). "
            "Wenn ein Ort fehlt, FRAGE den Benutzer."
        )
    ))
    
    register_tool(Tool(func=find_local_business_tool, args_schema=schemas.FindLocalBusinessArgs))
    register_tool(Tool(func=get_country_info_tool, args_schema=schemas.GetCountryInfoToolArgs))
    
    # 2. RSS: Mit expliziter Ausgabe-Anweisung und Erlaubnis für Memory-Nutzung
    register_tool(Tool(
        func=get_latest_news_rss, 
        args_schema=CleanGetLatestNewsRssToolArgs,
        description=(
            "Ruft aktuelle Schlagzeilen ab (z.B. Spiegel, Gamestar). "
            "Nutze User-Präferenzen aus dem Gedächtnis als Filter (query), falls vorhanden. "
            "WICHTIG: Du MUSST die erhaltenen Schlagzeilen als Liste in deiner Antwort ausgeben!"
        )
    ))
    
    # 3. WETTER: Parallel-Hinweis beibehalten
    register_tool(Tool(
        func=get_weather_from_api_tool, 
        args_schema=CleanGetWeatherFromApiToolArgs,
        description=(
            "Ruft Wettervorhersagen für eine GENANNTE Stadt ab. Rate keine Städte. "
            "Wenn der Nutzer AUCH nach Sehenswürdigkeiten fragt, rufe ZUSÄTZLICH das Wikipedia-Tool auf."
        )
    ))
    
    register_tool(Tool(func=generate_image_tool, args_schema=schemas.GenerateImageToolArgs))
    register_tool(Tool(func=search_past_conversation_summaries_tool, args_schema=schemas.CrossChatMemoryToolArgs))
    register_tool(Tool(func=perform_websearch, args_schema=schemas.WebsearchToolArgs))
    register_tool(Tool(func=save_mp3_tool, args_schema=schemas.SaveMp3Args))
    register_tool(Tool(func=create_pdf_from_markdown, args_schema=schemas.CreatePdfFromMarkdownArgs))
    
    # 4. WIKIPEDIA: Trigger-Worte
    register_tool(Tool(
        func=get_wikipedia_summary, 
        args_schema=CleanGetWikipediaSummaryArgs,
        description=(
            "Liefert Definitionen, Fakten und Infos zu Sehenswürdigkeiten (z.B. Eiffelturm). "
            "Nutze dies IMMER für Wissensfragen. Nutze es parallel zum Wetter-Tool bei Reisefragen."
        )
    ))
    
    # Filesystem Tools
    register_tool(Tool(func=create_file_tool, args_schema=schemas.CreateFileArgs))
    register_tool(Tool(func=read_file_tool, args_schema=schemas.ReadFileArgs))
    register_tool(Tool(func=delete_file_tool, args_schema=schemas.DeleteFileArgs))
    register_tool(Tool(func=list_directory_tool, args_schema=schemas.ListDirectoryArgs))
    register_tool(Tool(func=create_directory_tool, args_schema=schemas.CreateDirectoryArgs))
    register_tool(Tool(func=delete_directory_tool, args_schema=schemas.DeleteDirectoryArgs))
    register_tool(Tool(func=rename_file_tool, args_schema=schemas.RenameFileArgs))
    register_tool(Tool(func=move_file_tool, args_schema=schemas.MoveFileArgs))
    register_tool(Tool(func=move_files_tool, args_schema=schemas.MoveFilesArgs))
    register_tool(Tool(func=list_allowed_workspaces_tool, args_schema=schemas.ListAllowedWorkspacesArgs))

    # Kalender & E-Mail Tools
    register_tool(Tool(func=find_address_and_update_calendar_event, args_schema=schemas.FindAddressAndUpdateCalendarEventArgs))
    register_tool(Tool(
        func=get_latest_emails,
        args_schema=schemas.GetLatestEmailsArgs,
        description=(
            "Sucht und listet E-Mails auf. Benutze dieses Tool IMMER, wenn du E-Mails finden musst. "
            "Setze 'fetch_body' auf True, wenn die Anfrage des Benutzers eine Zusammenfassung, Übersetzung oder eine andere Detailanalyse des E-Mail-Inhalts erfordert."
        )
    ))
    register_tool(Tool(func=send_email, args_schema=schemas.SendEmailArgs))
    register_tool(Tool(func=find_contact_and_send_email, args_schema=schemas.FindContactAndSendEmailArgs))
    register_tool(Tool(func=read_email, args_schema=schemas.ReadEmailArgs))
    register_tool(Tool(func=get_calendar_events, args_schema=schemas.GetCalendarEventsArgs))
    register_tool(Tool(func=create_calendar_event, args_schema=schemas.CreateCalendarEventArgs))
    register_tool(Tool(func=delete_calendar_event, args_schema=schemas.DeleteCalendarEventArgs))
    register_tool(Tool(func=update_calendar_event, args_schema=schemas.UpdateCalendarEventArgs))
    register_tool(Tool(func=find_free_time_slots, args_schema=schemas.FindFreeTimeSlotsArgs))
    register_tool(Tool(func=update_calendar_event_description, args_schema=schemas.UpdateCalendarEventDescriptionArgs))
    register_tool(Tool(func=find_and_update_calendar_event, args_schema=schemas.FindAndUpdateCalendarEventArgs))

    # Kontakt & Memory Tools
    register_tool(Tool(
        func=create_or_update_contact_tool,
        args_schema=contact_schemas.CreateOrUpdateContactArgs,
        description="Benutze dieses Werkzeug ZWINGEND UND AUSSCHLIESSLICH für ALLE Anfragen, die das Erstellen oder Ändern eines Kontakts betreffen. Es ist das einzige Werkzeug für die Kontaktverwaltung. Es sucht zuerst nach dem Namen. Wenn ein Kontakt gefunden wird, werden die neuen Informationen hinzugefügt. Wenn kein Kontakt gefunden wird, wird ein komplett neuer Kontakt erstellt."
    ))
    register_tool(Tool(func=list_contacts_wrapper, args_schema=contact_schemas.ContactListArgs, description="Listet alle im Adressbuch gespeicherten Kontakte auf."))
    register_tool(Tool(func=delete_contact_by_id_wrapper, args_schema=contact_schemas.ContactDeleteArgs, description="Löscht einen Kontakt anhand seiner ID. Die ID muss zuerst durch eine Suche ermittelt werden."))
    register_tool(Tool(
        func=save_core_memory_tool,
        args_schema=schemas.SaveCoreMemoryToolArgs,
        description=(
            "Benutze dieses Werkzeug AUSSCHLIESSLICH, wenn der Benutzer einen **direkten und expliziten Befehl** gibt, "
            "sich etwas für die Zukunft zu merken. Achte auf Schlüsselphrasen wie: 'Merke dir, dass...', "
            "'Speichere die Information, dass...', 'Du sollst dir merken, dass...', 'Speichere in meinem Core Memory:'. "
            "WICHTIG: Bewahre den Kontext! Wenn eine Vorliebe an ein bestimmtes Objekt geknüpft ist (z.B. 'Ich mag Rennspiele auf der PS5'), "
            "speichere dies so, dass der Bezug erhalten bleibt (z.B. 'Auf der PS5 spiele ich am liebsten Rennspiele') "
            "und trenne es NICHT in zusammenhanglose Einzelfakten auf."
        )
    ))

# Initialisiere alle Tools beim Start
register_all_tools()

# --- Hilfsfunktionen für den Rest der Anwendung ---

def get_all_tool_definitions(): return [tool.llm_definition for tool in TOOL_REGISTRY.values()]
def get_all_tools() -> Dict[str, Tool]: return TOOL_REGISTRY
