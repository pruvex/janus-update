# FIX für PDF: LLMs nutzen oft 'file_name', wir zwingen sie zu 'filename'
class CleanCreatePdfArgs(BaseModel):
    content: str = Field(..., description="Der vollständige Markdown-Text für die PDF.")
    filename: str = Field(..., description="Der Dateiname. MUSS exakt 'filename' heißen (nicht file_name). Endet auf .pdf.")
    location: str = Field("Desktop", description="Speicherort: 'Desktop', 'Documents' oder 'Downloads'.")

# --- Tool-Klasse und Registrierung ---

class Tool:
    def __init__(self, func: Callable, args_schema: Optional[BaseModel] = None, description: Optional[str] = None):
        self.func = func
        self.args_schema = args_schema
        self.name = func.__name__
        self.description = description or inspect.getdoc(func)
        self.llm_definition = self._build_llm_definition()

    def _build_llm_definition(self) -> Dict[str, Any]:
        from datetime import datetime

        schema = (
            self.args_schema.model_json_schema()
            if self.args_schema
            else {"properties": {}, "required": []}
        )

        description = self.description or ""
        if "{current_date}" in description:
            current_date_str = datetime.now().strftime('%d. %B %Y')
            description = description.replace("{current_date}", current_date_str)

        return {
            "type": "function",
            "function": {
                "name": self.name,
                "description": description, # Verwende die modifizierte Beschreibung
                "parameters": {
                    "type": "object",
                    "properties": schema.get("properties", {}),
                    "required": schema.get("required", []),
                },
            },
        }


TOOL_REGISTRY: Dict[str, Tool] = {}


def register_tool(tool: Tool):
    TOOL_REGISTRY[tool.name] = tool


# --- Werkzeug-Funktionen ---

def get_wikipedia_summary(query: str, lang: str = 'de') -> Dict[str, str]:
    """
    Benutze dieses Werkzeug IMMER für Anfragen nach Definitionen, Biografien, historischen Ereignissen oder etablierten Konzepten (Wissenschaft, Kunst etc.).
    Es liefert eine präzise und verlässliche Zusammenfassung direkt aus Wikipedia. Es ist der Websuche für Wissensfragen vorzuziehen.
    """
    try:
        wiki_wiki = wikipediaapi.Wikipedia(
            'Janus AI Assistant (janus.projekt@example.com)',
            lang,
            timeout=10
        )
        page = wiki_wiki.page(query)

        if not page.exists():
            logger.warning(f"Wikipedia-Artikel für '{query}' nicht gefunden.")
            return {"status": "success", "output": f"Ich konnte leider keinen Wikipedia-Artikel zum Thema '{query}' finden."}

        summary_sentences = page.summary.split('.')
        short_summary = ". ".join(summary_sentences[:3]) + "."
        
        logger.info(f"Wikipedia-Zusammenfassung für '{query}' erfolgreich abgerufen.")
        return {"status": "success", "output": short_summary}

    except Exception as e:
        logger.error(f"Fehler bei der Wikipedia-Abfrage für '{query}': {e}", exc_info=True)
        return {"status": "error", "message": f"Bei der Abfrage von Wikipedia ist ein Fehler aufgetreten: {e}"}


def split_text_into_chunks(text: str, max_length: int = 4000):
    """
    Teilt einen SSML-Text intelligent in Chunks unterhalb der max_length auf,
    ohne SSML-Tags zu zerschneiden. Behandelt Sätze und Tags als unteilbare Einheiten.
    """
    logger.info("Starting intelligent SSML chunking...")
    
    inner_ssml = re.sub(r'</?speak>', '', text, flags=re.IGNORECASE).strip()
    parts = re.findall(r'(<[^>]+>|[^.!?]+(?:[.!?]|$))', inner_ssml)
    
    chunks = []
    current_chunk = ""
    
    for part in parts:
        part_stripped = part.strip()
        if not part_stripped:
            continue
            
        if len(current_chunk) + len(part_stripped) + 1 > max_length:
            if current_chunk:
                chunks.append(f"<speak>{current_chunk.strip()}</speak>")
            current_chunk = part_stripped
        else:
            current_chunk += " " + part_stripped
    
    if current_chunk:
        chunks.append(f"<speak>{current_chunk.strip()}</speak>")
    
    logger.info(f"SSML text successfully split into {len(chunks)} chunks.")
    return chunks

async def save_mp3_tool(content: str, filename: str, voice: str = "fable") -> Dict[str, str]:
    """
    Benutze dieses Werkzeug NUR, wenn der Benutzer explizit darum bittet, einen Text als MP3-Datei zu speichern.
    Es ist NICHT zum Vorlesen im Chat gedacht. Es synthetisiert Text zu Audio und speichert ihn in einer Datei auf dem Desktop.
    """
    if not filename.lower().endswith('.mp3'):
        filename += '.mp3'
    filename = os.path.basename(filename)
    desktop_path = get_desktop_path()
    if not desktop_path:
        return {"status": "error", "message": "Desktop-Pfad nicht gefunden."}
    
    speech_file_path = os.path.join(desktop_path, filename)

    is_ssml = content.strip().startswith("<speak>") and content.strip().endswith("</speak>")

    if is_ssml:
        logger.info(f"SSML-Text erkannt. Nutze OpenAI TTS mit Stimme '{voice}' für hohe Qualität.")
        try:
            api_key_from_env = os.environ.get("OPENAI_API_KEY")
            if not api_key_from_env:
                logger.error("OPENAI_API_KEY environment variable not found for SSML.")
                return {"status": "error", "message": "OpenAI API key is not configured for SSML."}
            
            local_client = AsyncOpenAI(api_key=api_key_from_env)
            ssml_chunks = split_text_into_chunks(content)
            audio_segments = []

            for i, chunk in enumerate(ssml_chunks):
                logger.info(f"Synthesizing chunk {i+1}/{len(ssml_chunks)}...")
                response = await local_client.audio.speech.create(
                    model="tts-1-hd",
                    voice=voice,
                    input=chunk
                )
                audio_data = io.BytesIO(response.content)
                segment = AudioSegment.from_file(audio_data, format="mp3")
                audio_segments.append(segment)

            logger.info("Füge alle Audio-Teile zusammen...")
            final_audio = sum(audio_segments, AudioSegment.empty())
            final_audio.export(speech_file_path, format="mp3")

            success_msg = f"Audiodatei erfolgreich mit Stimme '{voice}' unter '{speech_file_path}' gespeichert."
            logger.info(success_msg)
            return {"status": "success", "message": success_msg}
        except Exception as e:
            error_msg = f"Fehler bei der OpenAI TTS-Synthese: {e}"
            logger.error(error_msg, exc_info=True)
            return {"status": "error", "message": error_msg}
    else:
        logger.info("Reiner Text erkannt. Nutze lokale TTS-Engine (Piper).")
        try:
            from backend.main import load_config
            config = load_config()
            tts_service_instance = TTSService(config=config, tts_settings=config.get("tts_settings", {}))
            audio_bytes = tts_service_instance.synthesize(
                text=content,
                voice='piper_de_DE-thorsten-medium',
                speed=1.0
            )
            
            if audio_bytes:
                with open(speech_file_path, "wb") as f:
                    f.write(audio_bytes)
                success_msg = f"Audiodatei erfolgreich mit lokaler Stimme unter '{speech_file_path}' gespeichert."
                logger.info(success_msg)
                return {"status": "success", "message": success_msg}
            else:
                raise RuntimeError("Lokale TTS hat keine Audiodaten zurückgegeben.")

        except Exception as e:
            error_msg = f"Fehler bei der lokalen TTS-Synthese: {e}"
            logger.error(error_msg, exc_info=True)
            return {"status": "error", "message": error_msg}

def get_country_info_tool(country_name: str, info_type: str) -> Dict[str, str]:
    """
    Benutze dieses Werkzeug, um spezifische Fakten über ein Land abzurufen, wie Hauptstadt, Bevölkerung, Währung, Sprachen oder Region.
    Dieses Tool ist extrem schnell und präzise für geografische und politische Fakten.
    """
    try:
        country_mapping = {
            "deutschland": "germany", "frankreich": "france", "spanien": "spain",
            "italien": "italy", "österreich": "austria", "schweiz": "switzerland",
            "usa": "united states of america", "vereinigte staaten": "united states of america"
        }
        search_name = country_mapping.get(country_name.lower(), country_name)
        api_url = f"https://restcountries.com/v3.1/name/{search_name}?fullText=true"
        response = requests.get(api_url, timeout=10)
        response.raise_for_status()
        data = response.json()[0]

        output = ""
        info_type = info_type.lower()

        if info_type == 'capital':
            output = f"Die Hauptstadt von {country_name.title()} ist {data.get('capital', ['N/A'])[0]}."
        elif info_type == 'population':
            output = f"{country_name.title()} hat eine Einwohnerzahl von ca. {data.get('population', 'N/A'):,}."
        elif info_type == 'currency':
            currencies = data.get('currencies', {})
            curr_code = list(currencies.keys())[0]
            curr_name = currencies[curr_code].get('name', 'N/A')
            output = f"Die Währung in {country_name.title()} ist der {curr_name} ({curr_code})."
        elif info_type == 'languages':
            languages = ", ".join(list(data.get('languages', {}).values()))
            output = f"In {country_name.title()} werden folgende Sprachen gesprochen: {languages}."
        elif info_type == 'region':
            output = f"{country_name.title()} liegt in der Region {data.get('region', 'N/A')} ({data.get('subregion', '')})."
        else:
            return {"status": "error", "message": f"Unbekannter info_type: '{info_type}'."}

        logger.info(f"Länder-API erfolgreich abgefragt: {output}")
        return {"status": "success", "output": output}
    except requests.exceptions.HTTPError as e:
         logger.error(f"Land '{country_name}' nicht gefunden oder API-Fehler: {e}", exc_info=True)
         return {"status": "error", "message": f"Ich konnte keine Informationen für das Land '{country_name}' finden."}
    except Exception as e:
        logger.error(f"Unerwarteter Fehler im Länder-Tool: {e}", exc_info=True)
        return {"status": "error", "message": f"Ein unerwarteter Fehler ist aufgetreten: {e}"}

def _get_weather_code_description(code: int) -> str:
    """Wandelt den WMO-Wettercode in eine verständliche Beschreibung um."""
    weather_codes = {
        0: "Klarer Himmel", 1: "Leicht bewölkt", 2: "Teils bewölkt", 3: "Bedeckt",
        45: "Nebel", 48: "Raureifnebel", 51: "Leichter Nieselregen", 53: "Mäßiger Nieselregen",
        55: "Dichter Nieselregen", 56: "Leichter gefrierender Nieselregen", 57: "Dichter gefrierender Nieselregen",
        61: "Leichter Regen", 63: "Mäßiger Regen", 65: "Starker Regen",
        66: "Leichter gefrierender Regen", 67: "Starker gefrierender Regen", 71: "Leichter Schneefall",
        73: "Mäßiger Schneefall", 75: "Starker Schneefall", 77: "Schneekörner",
        80: "Leichte Regenschauer", 81: "Mäßige Regenschauer", 82: "Heftige Regenschauer",
        85: "Leichte Schneeschauer", 86: "Starke Schneeschauer", 95: "Gewitter",
        96: "Gewitter mit leichtem Hagel", 99: "Gewitter mit starkem Hagel",
    }
    return weather_codes.get(code, "Unbekanntes Wetterphänomen")

def get_weather_from_api_tool(city: str, date_str: Optional[str] = None) -> Dict[str, str]:
    """
    Benutze IMMER dieses Werkzeug, um die Wettervorhersage für eine Stadt abzurufen. Akzeptiert auch Datumsangaben in natürlicher Sprache (z.B. 'Samstag', 'übermorgen', '15. November'), um eine Vorhersage für einen bestimmten Tag zu erhalten. Wenn kein Datum angegeben wird, wird die Vorhersage für den nächsten verfügbaren Tag zurückgegeben.
    Es ist schneller und genauer als eine allgemeine Websuche.
    """
    geolocator = Nominatim(user_agent="janus_projekt_weather_tool")
    try:
        location = geolocator.geocode(city)
        if not location:
            return {"status": "error", "message": f"Stadt '{city}' konnte nicht gefunden werden."}

        lat, lon = location.latitude, location.longitude
        logger.info(f"Koordinaten für '{city}' gefunden: Lat {lat}, Lon {lon}")

        target_date = None
        if date_str:
            try:
                target_date = parser.parse(date_str, default=datetime.now())
                if target_date.date() < datetime.now().date():
                    return {"status": "info", "output": "Ich kann die Wettervorhersage nur für die Zukunft abrufen."}
            except parser.ParserError:
                target_date = None

        api_url = (
            f"https://api.open-meteo.com/v1/forecast?latitude={lat}&longitude={lon}"
            "&daily=weather_code,temperature_2m_max,temperature_2m_min,precipitation_probability_max,wind_speed_10m_max"
            "&timezone=Europe/Berlin&forecast_days=7"
        )
        response = requests.get(api_url, timeout=10)
        response.raise_for_status()
        data = response.json()
        daily_data = data.get("daily", {})
        forecast_dates = daily_data.get("time", [])
        day_index = 0 

        if target_date and forecast_dates:
            try:
                day_index = [datetime.fromisoformat(d).date() for d in forecast_dates].index(target_date.date())
            except ValueError:
                return {"status": "info", "output": f"Ich konnte keine Wettervorhersage für den {target_date.strftime('%d.%m.%Y')} finden."}
        
        if not forecast_dates or day_index >= len(forecast_dates):
            return {"status": "error", "message": "Konnte keine Vorhersagedaten abrufen."}

        weather_date = daily_data["time"][day_index]
        temp_max = daily_data["temperature_2m_max"][day_index]
        temp_min = daily_data["temperature_2m_min"][day_index]
        prec_prob = daily_data["precipitation_probability_max"][day_index]
        wind_speed_max = daily_data["wind_speed_10m_max"][day_index]
        weather_desc = _get_weather_code_description(daily_data["weather_code"][day_index])

        output = (
            f"Wettervorhersage für {city.title()} am {datetime.fromisoformat(weather_date).strftime('%d.%m.%Y')}: "
            f"Es wird {weather_desc.lower()} erwartet. Höchsttemperatur: {temp_max}°C, Tiefsttemperatur: {temp_min}°C. "
            f"Niederschlagswahrscheinlichkeit: {prec_prob}%. Windböen bis zu {wind_speed_max} km/h."
        )
        logger.info(f"Detaillierte Wetter-API erfolgreich abgefragt: {output}")
        return {"status": "success", "output": output}
    except Exception as e:
        logger.error(f"Fehler im Wetter-Tool: {e}", exc_info=True)
        return {"status": "error", "message": f"Ein unerwarteter Fehler ist aufgetreten: {e}"}

RSS_FEEDS = {
    "tagesschau": "https://www.tagesschau.de/xml/rss2", "spiegel": "https://www.spiegel.de/schlagzeilen/tops/index.rss",
    "zeit": "https://newsfeed.zeit.de/index", "heise": "https://www.heise.de/rss/heise-atom.xml",
    "gamestar": "https://www.gamestar.de/news/rss/news.rss", "reuters": "https://www.reuters.com/rssFeed/topNews",
    "bbc": "https://feeds.bbci.co.uk/news/world/rss.xml"
}

async def get_latest_news_rss(query: Optional[str] = None, source: Optional[str] = None, url: Optional[str] = None) -> Dict[str, str]:
    """
    Ruft journalistische Artikel ab. Versucht zuerst RSS-Feeds. 
    Wenn eine spezifische Suche ('query') im RSS keine Treffer liefert, 
    wird automatisch eine Websuche als Fallback durchgeführt.
    """
    # --- FIX FÜR HALLUZINIERTE PARAMETER ---
    if url:
        logger.warning(f"Tool 'get_latest_news_rss' wurde mit halluziniertem Parameter 'url={url}' aufgerufen.")
        if not source:
            url_lower = url.lower()
            for key in RSS_FEEDS.keys():
                if key in url_lower:
                    source = key
                    break
    # ---------------------------------------

    # Hilfsfunktion für sauberen Download mit User-Agent (verhindert Blockaden bei Spiegel/Gamestar)
    def _download_and_parse_feed(feed_url):
        try:
            headers = {
                'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/107.0.0.0 Safari/537.36',
                'Accept': 'application/xml,application/rss+xml,application/rdf+xml;q=0.8,text/xml;q=0.8,application/xhtml+xml;q=0.5,text/html;q=0.5,*/*;q=0.1',
                'Accept-Language': 'de-DE,de;q=0.9,en-US;q=0.8,en;q=0.7',
            }
            response = requests.get(feed_url, headers=headers, timeout=15)
            logger.info(f"Anfrage an RSS-Feed {feed_url} gesendet. Status: {response.status_code}")
            if response.status_code != 200:
                logger.error(f"Fehler beim Abrufen des Feeds von {feed_url}. Status-Code: {response.status_code}")
                return None
            return feedparser.parse(response.content)
        except Exception as e:
            logger.error(f"RSS Download oder Parse-Fehler für {feed_url}: {e}", exc_info=True)
            return None

    async def fetch_feed(name, feed_url):
        try:
            loop = asyncio.get_running_loop()
            # Wir nutzen requests im Thread-Pool für Stabilität
            feed = await loop.run_in_executor(None, _download_and_parse_feed, feed_url)
            
            if not feed or feed.bozo:
                error_msg = feed.get('bozo_exception') if feed else "Download failed"
                logger.warning(f"Fehler beim Parsen von {name}: {error_msg}")
                return name, []
            return name, feed.entries
        except Exception as e:
            logger.error(f"Fehler beim Abrufen von {name}: {e}")
            return name, []

    # 1. Direkte Quellenabfrage
    if source:
        source = source.lower()
        if source not in RSS_FEEDS:
            return {"status": "error", "message": f"Unbekannte Quelle. Verfügbar sind: {list(RSS_FEEDS.keys())}"}
        
        _, entries = await fetch_feed(source, RSS_FEEDS[source])
        
        # WICHTIG: Wenn der Feed leer ist (z.B. Cloudflare-Block), SOFORT Fallback auf Websuche
        if not entries:
             logger.info(f"RSS-Feed von {source} leer. Starte Fallback-Websuche.")
             web_result = await perform_websearch(query=f"{source} aktuelle schlagzeilen")
             return {"status": "success", "output": f"Der direkte RSS-Feed von {source} war nicht erreichbar. Hier sind aktuelle Web-Ergebnisse:\n{web_result.get('text', 'Keine Ergebnisse.')}"}

        if query:
            query_lower = query.lower()
            # Wir filtern nur, wenn die Query NICHT "schlagzeilen" oder "news" ist
            if query_lower and query_lower not in ["schlagzeilen", "news", "nachrichten"]:
                # Zerlege Query in einzelne Suchbegriffe (getrennt durch Leerzeichen oder Semikolon)
                keywords = [k.strip() for k in query_lower.replace(';', ' ').split() if k.strip()]
                
                filtered_entries = []
                for e in entries:
                    title = e.get('title', '').lower()
                    summary = e.get('summary', '').lower()
                    content = title + " " + summary
                    
                    # Ein Artikel passt, wenn ALLE Keywords enthalten sind (strikter Filter)
                    # ODER wenn bei vielen Keywords (>=3) zumindest die MEISTEN enthalten sind.
                    # Hier: Wir verlangen, dass mindestens eines der Haupt-Keywords vorkommt.
                    if any(k in content for k in keywords):
                        filtered_entries.append(e)
                entries = filtered_entries
            
            if not entries:
                logger.info(f"Keine RSS-Treffer in {source} für '{query}'. Starte Fallback-Websuche.")
                web_result = await perform_websearch(query=f"{source} {query} news")
                return {"status": "success", "output": f"Im RSS-Feed von {source} wurde nichts gefunden, aber hier ist das Ergebnis der Websuche:\n{web_result.get('text', 'Keine Ergebnisse.')}"}

        output_lines = [f"Hier sind die Top-Schlagzeilen von '{source.title()}':"] + [f"- {entry.title}" for entry in entries[:5]]
        return {"status": "success", "output": "\n".join(output_lines)}

    # 2. Globale Suche (Query ohne Source)
    if query:
        logger.info(f"Suche nach '{query}' über {len(RSS_FEEDS)} Feeds...")
        tasks = [fetch_feed(name, url) for name, url in RSS_FEEDS.items()]
        results = await asyncio.gather(*tasks)
        
        query_lower = query.lower()
        found_articles = []
        for source_name, entries in results:
            # Zerlege Query in einzelne Suchbegriffe (getrennt durch Leerzeichen oder Semikolon)
            keywords = [k.strip() for k in query_lower.replace(';', ' ').split() if k.strip()]
            
            for entry in entries:
                title = entry.get('title', '').lower()
                summary = entry.get('summary', '').lower()
                content = title + " " + summary
                
                # Ein Artikel passt, wenn mindestens eines der Keywords enthalten ist
                if any(k in content for k in keywords):
                    entry.source_name = entry.get('source_name', source_name)
                    found_articles.append(entry)
        
        if not found_articles:
            logger.info(f"Keine RSS-Treffer für '{query}'. Starte automatische Fallback-Websuche.")
            web_result = await perform_websearch(query=f"{query} News aktuell")
            
            fallback_text = web_result.get("text", "")
            if not fallback_text or "Keine Ergebnisse" in fallback_text:
                 return {"status": "success", "output": f"Ich konnte weder in den RSS-Feeds noch im Web aktuelle Nachrichten zu '{query}' finden."}
            
            return {"status": "success", "output": f"In den direkten RSS-Feeds war nichts Spezifisches zu finden, aber hier sind aktuelle Web-Ergebnisse:\n{fallback_text}"}
            
        unique_articles = list({article.link: article for article in found_articles}.values())
        output_lines = [f"Hier sind die Top-Ergebnisse aus den RSS-Feeds für '{query}':"] + [f"- '{a.title}' (Quelle: {a.get('source_name', 'News').title()})" for a in unique_articles[:5]]
        return {"status": "success", "output": "\n".join(output_lines)}
        
    if url:
         return {"status": "error", "message": "Ich konnte die URL nicht verarbeiten."}

    return {"status": "error", "message": "Bitte gib eine Quelle oder ein Thema an."}
    return {"status": "error", "message": "Bitte gib eine Quelle oder ein Thema an."}

@retry(stop=stop_after_attempt(3), wait=wait_exponential(multiplier=1, min=2, max=10))
async def generate_image_tool(api_key: str, prompt: str, size: str = "1024x1024", quality: str = "standard", **kwargs) -> Dict:
    """Generiert ein Bild basierend auf einer Texteingabe unter Verwendung von DALL-E 3."""
    provider = OpenAIServiceProvider()
    response = await provider.generate_image(api_key, "dall-e-3", prompt, size=size, quality=quality, **kwargs)
    return {"url": response.get("image_url"), "usage": response.get("usage"), "cost": response.get("cost")}

