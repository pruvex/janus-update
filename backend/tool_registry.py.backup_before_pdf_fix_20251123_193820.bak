logger = logging.getLogger("janus_backend")


def _normalize_url(url: Optional[str]) -> Optional[str]:
    """
    Normalisiert eine URL, indem sichergestellt wird, dass ein Protokoll vorhanden ist.
    Priorisiert https.
    """
    if not url:
        return None
    
    url = url.strip().strip("'<>'")
    if not url:
        return None
    
    # Wenn die URL bereits ein Protokoll hat, belassen wir sie so.
    if url.startswith('http://') or url.startswith('https://'):
        return url
        
    # Wenn kein Protokoll vorhanden ist, fügen wir https:// hinzu.
    logger.info(f"Normalizing URL: '{url}' to 'https://{url}'")
    return 'https://' + url


