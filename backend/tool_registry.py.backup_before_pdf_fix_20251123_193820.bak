async def find_local_business_tool(query: str, location: Optional[str] = None) -> Dict[str, Any]:
    """
    Benutze DIESES WERKZEUG IMMER UND AUSSCHLIESSLICH, um nach lokalen Orten, Geschäften, Restaurants, Dienstleistungen, **Freizeitaktivitäten, Museen, Sehenswürdigkeiten oder Events** zu suchen.
    
    WICHTIGE ANWEISUNG ZUR AUSFÜHRUNG:
    Wenn der Benutzer eine Frage stellt wie "Kannst du mir ein Restaurant empfehlen?", "Was kann man hier unternehmen?" oder "Schlag mir Aktivitäten vor", 
    interpretiere dies als DIREKTEN BEFEHL zur sofortigen Suche. 
    Frage NICHT um Erlaubnis ("Soll ich suchen?"). Führe die Suche SOFORT aus.
    
    Es führt eine mehrstufige, detaillierte Suche durch, um möglichst vollständige Informationen zu sammeln.
    """
    if not location:
        return {"status": "clarification_needed", "output": "Ich benötige einen Ort, um lokale Geschäfte zu finden. Wo soll ich für dich suchen?"}

    logger.info(f"Starting multi-step local business search for '{query}' in '{location}'.")

    try:
        # Lade API-Schlüssel und initialisiere den Client
        api_key = keyring.get_password("Janus-Projekt", "openai")
        if not api_key:
            return {"status": "error", "output": "OpenAI API key is not configured."}
        local_client = AsyncOpenAI(api_key=api_key)

        # --- SCHRITT 1: Breite Suche zur Identifizierung von Kandidaten ---
        initial_search_query = f"Liste von '{query}' in '{location}'"
        logger.info(f"Step 1: Performing broad search with query: '{initial_search_query}'")
        search_results = await perform_websearch_service(query=initial_search_query, api_key=api_key, provider="openai")
        search_text = search_results.get("text", "")
        if not search_text:
            return {"status": "error", "output": "Keine Ergebnisse bei der initialen Websuche gefunden."}

        # --- SCHRITT 2: Extraktion der Namen aus der breiten Suche ---
        name_extraction_prompt = f"""
        Extrahiere aus dem folgenden Text eine einfache Liste von Geschäftsnamen.
        Antworte NUR mit einem JSON-Objekt, das einen Schlüssel 'names' enthält, der ein Array von Strings ist.
        Beispiel: {{"names": ["Restaurant A", "Pizzeria B", "Cafe C"]}}
        
        Text:
        {search_text}
        
        JSON-Antwort:
        """
        logger.info("Step 2: Extracting business names from broad search results.")
        name_extraction_response = await local_client.chat.completions.create(
            model="gpt-4o-mini",
            messages=[{"role": "user", "content": name_extraction_prompt}],
            response_format={"type": "json_object"}
        )
        candidate_names_data = json.loads(name_extraction_response.choices[0].message.content)
        candidate_names = candidate_names_data.get("names", [])
        
        if not candidate_names:
            return {"status": "success", "output": "Ich konnte zwar allgemeine Informationen finden, aber keine spezifischen Geschäftsnamen extrahieren."}
        
        logger.info(f"Found {len(candidate_names)} candidates: {candidate_names}")

        # --- SCHRITT 3: Gezielte Einzelsuchen zur Anreicherung ---
        enriched_contacts = []
        for name in candidate_names[:5]:  # Begrenze auf die ersten 5 Ergebnisse, um Kosten/Zeit zu sparen
            detail_search_query = f"Adresse, Telefonnummer, Website und kurze Beschreibung für '{name}' in '{location}'"
            logger.info(f"Step 3: Performing detailed search for '{name}' with query: '{detail_search_query}'")
            detail_results = await perform_websearch_service(query=detail_search_query, api_key=api_key, provider="openai")
            detail_text = detail_results.get("text", "")

            if not detail_text:
                continue

            data_extraction_prompt = f"""
            Extrahiere aus dem folgenden Text die Detailinformationen für das Geschäft '{name}'.
            Antworte NUR mit einem einzigen JSON-Objekt.
            Das Objekt muss die Schlüssel 'name', 'address', 'phone', 'email', 'website' und 'description' haben.
            Setze den Wert auf null, wenn die Information nicht gefunden wird. Gib den Namen '{name}' im 'name'-Feld zurück.
            
            Text:
            {detail_text}
            
            JSON-Antwort:
            """
            detail_extraction_response = await local_client.chat.completions.create(
                model="gpt-4o-mini",
                messages=[{"role": "user", "content": data_extraction_prompt}],
                response_format={"type": "json_object"}
            )
            try:
                extracted_data = json.loads(detail_extraction_response.choices[0].message.content)
                # Stelle sicher, dass der Name korrekt ist und füge es der Liste hinzu
                extracted_data['name'] = name 
                enriched_contacts.append(extracted_data)
                logger.info(f"Successfully enriched data for '{name}'.")
            except json.JSONDecodeError:
                logger.warning(f"Failed to parse JSON for '{name}'.")
                continue
        
        if not enriched_contacts:
            return {"status": "success", "output": "Keine spezifischen Geschäftsdaten gefunden, obwohl Namen identifiziert wurden."}

        # --- SCHRITT 4: (Optional) Ergebnisse in der Kontaktdatenbank speichern ---
        db_session = next(database.get_db())
        try:
            for contact_data in enriched_contacts:
                # --- HIER IST DER GOLDSTANDARD-FIX ---
                if contact_data.get("website"):
                    contact_data["website"] = _normalize_url(contact_data["website"])
                # --- ENDE DES FIXES ---
                
                if contact_data.get("name") and not crud.search_contacts_by_name(db_session, name_query=contact_data["name"]):
                    logger.info(f"Saving new business contact to database: '{contact_data['name']}'")
                    contact_to_create = contact_schemas.ContactCreate(**contact_data, category="Business")
                    crud.create_contact(db_session, contact=contact_to_create)
        finally:
            db_session.close()

        logger.info("Multi-step local business search completed successfully.")
        return {"status": "success", "output": json.dumps(enriched_contacts, ensure_ascii=False, indent=2)}

    except Exception as e:
        logger.error(f"Error in multi-step local business search: {e}", exc_info=True)
        return {"status": "error", "output": f"Bei der Suche nach lokalen Geschäften ist ein Fehler aufgetreten: {str(e)}"}
        return {"status": "error", "output": f"Bei der Suche nach lokalen Geschäften ist ein Fehler aufgetreten: {str(e)}"}

async def perform_websearch(query: str, model: Optional[str] = None) -> Dict[str, Any]:
    """Wrapper-Funktion für perform_websearch, die den API-Schlüssel und Provider intern abruft."""
    try:
        from backend.main import load_config
        config = load_config()
        provider = config.get("last_used_provider", "openai")
        api_key = keyring.get_password("Janus-Projekt", provider)
        if not api_key:
            return {"status": "error", "output": f"API key für {provider} nicht konfiguriert."}
        # WICHTIG: Hier den umbenannten Service aufrufen
        return await perform_websearch_service(query=query, api_key=api_key, provider=provider, model=model)
    except Exception as e:
        logger.error(f"Fehler im perform_websearch wrapper: {e}", exc_info=True)
        return {"status": "error", "output": f"Ein Fehler ist bei der Websuche aufgetreten: {str(e)}"}

# --- Wrapper-Funktionen für Kontakt-Tools ---

def list_contacts_wrapper() -> dict:
    """Ein Wrapper für contact_manager.list_contacts, der die DB-Session intern beschafft."""
    db = next(database.get_db())
    try:
        return contact_manager.list_contacts(db=db)
    finally:
        db.close()

def search_contacts_wrapper(name_query: str) -> dict:
    """Ein Wrapper für die Kontaktsuche, der die DB-Session intern beschafft."""
    db = next(database.get_db())
    try:
        # Rufe direkt die korrekte CRUD-Funktion auf.
        contacts = crud.search_contacts_by_name(db, name_query=name_query)
        # Pydantic-Modelle in Dictionaries umwandeln für JSON-Serialisierung
        return [contact.model_dump() for contact in contacts]
    finally:
        db.close()

async def update_contact_tool_wrapper(
    name_query: str,
    new_name: Optional[str] = None,
    email: Optional[str] = None,
    phone: Optional[str] = None,
    address: Optional[str] = None,
    website: Optional[str] = None,
    notes: Optional[str] = None,
    category: Optional[str] = None
) -> dict:
    """Wrapper, um die Details eines bestehenden Kontakts zu aktualisieren."""
    db = next(database.get_db())
    try:
        # 1. Finde den Kontakt
        search_results = crud.search_contacts_by_name(db, name_query)
        if not search_results:
            return {"status": "error", "message": f"Kontakt '{name_query}' nicht gefunden."}
        if len(search_results) > 1:
            logger.warning(f"Mehrere Kontakte für '{name_query}' gefunden. Aktualisiere den ersten Treffer (ID: {search_results[0].id}).")
        
        target_contact = search_results[0]

        # 2. Baue das 'updates'-Dictionary
        updates = {}
        if new_name:
            updates['name'] = new_name
        if email:
            updates['email'] = email
        if phone:
            updates['phone'] = phone
        if address:
            updates['address'] = address
        if website:
            updates['website'] = website
        if notes:
            # Spezieller Fall für Notizen: Anhängen statt überschreiben
            existing_notes = target_contact.notes or ""
            updates['notes'] = f"{existing_notes}\n{notes}".strip()
        if category:
            updates['category'] = category

        if not updates:
            return {"status": "info", "message": "Keine neuen Informationen zum Aktualisieren angegeben."}

        # 3. Rufe die Kernlogik auf
        return await contact_manager.update_contact_details(
            db=db,
            contact_id=target_contact.id,
            updates=updates
        )
    finally:
        db.close()

async def update_contact_details_wrapper(contact_id: int, updates: dict, name: Optional[str] = None) -> dict:
    """Wrapper to update contact details, handling the DB session internally."""
    db = next(database.get_db())
    try:
        # Die 'updates' werden jetzt direkt durchgereicht, wie es das Schema vorsieht.
        # 'name' wird als optionaler Suchparameter beibehalten.
        return await contact_manager.update_contact_details(
            db=db, 
            contact_id=contact_id,
            name_query=name, 
            updates=updates
        )
    finally:
        db.close()

def delete_contact_by_id_wrapper(contact_id: int) -> dict:
    """Ein Wrapper für contact_manager.delete_contact_by_id, der die DB-Session intern beschafft."""
    db = next(database.get_db())
    try:
        return contact_manager.delete_contact_by_id(db=db, contact_id=contact_id)
    finally:
        db.close()

async def create_or_update_contact_tool(
    name: str,
    email: Optional[str] = None,
    phone: Optional[str] = None,
    address: Optional[str] = None,
    notes: Optional[str] = None,
    category: Optional[str] = "Privat"
) -> dict:
    """
    Benutze dieses Werkzeug IMMER, um einen Kontakt zu erstellen oder zu aktualisieren.
    Es sucht zuerst nach einem Kontakt mit dem angegebenen Namen.
    - Wenn ein Kontakt gefunden wird, werden die neuen Informationen (E-Mail, Telefon etc.) hinzugefügt.
    - Wenn kein Kontakt gefunden wird, wird ein komplett neuer Kontakt erstellt.
    """
    db = next(database.get_db())
    try:
        # Suche nach einem existierenden Kontakt
        existing_contacts = crud.search_contacts_by_name(db, name_query=name)
        
        updates = {
            "email": email,
            "phone": phone,
            "address": address,
            "notes": notes,
            "category": category,
        }
        # Entferne leere Werte, um bestehende Daten nicht zu überschreiben
        updates = {k: v for k, v in updates.items() if v is not None}

        if existing_contacts:
            # Kontakt existiert -> Aktualisieren
            contact_to_update = existing_contacts[0]
            logger.info(f"Kontakt '{name}' gefunden. Aktualisiere mit: {updates}")
            updated_contact = crud.update_contact(db, contact_id=contact_to_update.id, updates=updates)
            return {
                "status": "success", 
                "message": f"Kontakt '{updated_contact.name}' erfolgreich aktualisiert.", 
                "contact": contact_schemas.ContactResponse.model_validate(updated_contact).model_dump()
            }
        else:
            # Kontakt existiert nicht -> Neu erstellen
            logger.info(f"Kontakt '{name}' nicht gefunden. Erstelle neuen Kontakt mit: {updates}")
            new_contact_data = contact_schemas.ContactCreate(name=name, **updates)
            created_contact = crud.create_contact(db, contact=new_contact_data)
            return {
                "status": "success", 
                "message": f"Neuer Kontakt '{created_contact.name}' erfolgreich erstellt.", 
                "contact": contact_schemas.ContactResponse.model_validate(created_contact).model_dump()
            }

    finally:
        db.close()

async def find_contact_and_send_email(name_query: str, subject: str, body: str) -> dict:
    """
    Benutze dieses Werkzeug, um eine E-Mail an einen im Adressbuch gespeicherten Kontakt anhand seines Namens zu senden.
    Das Werkzeug sucht automatisch die korrekte E-Mail-Adresse und versendet dann die Nachricht.
    """
    db = next(database.get_db())
    try:
        # SCHRITT 1: Kontakt suchen
        contacts = crud.search_contacts_by_name(db, name_query=name_query)
        if not contacts:
            return {"status": "error", "message": f"Kontakt '{name_query}' konnte nicht im Adressbuch gefunden werden."}
        
        target_contact = contacts[0]
        if not target_contact.email:
            return {"status": "error", "message": f"Kontakt '{target_contact.name}' hat keine gespeicherte E-Mail-Adresse."}

        # SCHRITT 2: E-Mail senden
        email_address = target_contact.email
        # Da send_email nicht async ist, führen wir es in einem Thread aus.
        result = await asyncio.to_thread(send_email, to=email_address, subject=subject, body=body)
        return result

    finally:
        db.close()

