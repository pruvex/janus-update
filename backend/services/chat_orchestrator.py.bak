import logging
import json
import os
import base64
import asyncio
import keyring
from datetime import datetime
from typing import Dict, Optional

from backend.services.rag_manager import query_knowledge_base

from fastapi import HTTPException
from sqlalchemy.orm import Session

from backend.data import crud, database, schemas
from backend.services import llm_gateway, image_manager, memory_extractor, memory_manager
from backend.services.context_manager import ContextManager
from backend.services.tool_executor import ToolExecutor
from backend.services.chat.tool_selector import ToolSelector
from backend.services.chat.context_builder import ContextBuilder
from backend.services.planner_service import generate_decision_context
from backend.services.verifier_service import verify_decision_integrity
from backend.data.schemas import ExtractedFact
from backend.utils import intent_classifier
from backend.utils.config_loader import initialize_file_from_template
from backend.utils.paths import get_app_data_dir

logger = logging.getLogger("janus_backend")

class ChatOrchestrator:
    def __init__(
        self,
        db: Session,
        context_manager: ContextManager,
        model_catalog: Dict,
        config_file_path: str,
        template_config_file_path: str,
        personalities_file_path: str,
        template_personalities_file_path: str,
    ):
        self.db = db
        self.context_manager = context_manager
        self.model_catalog = model_catalog
        self.config_file = config_file_path
        self.personalities_file = personalities_file_path
        
        # Initialize Helpers
        initialize_file_from_template(template_config_file_path, config_file_path)
        initialize_file_from_template(template_personalities_file_path, personalities_file_path)
        
        self.context_builder = ContextBuilder(db)
        
        # State Caches
        self.last_response_id_per_chat = {}
        self.last_ssml_response_per_chat = {}
        self.last_email_list_per_chat = {}  # Simple dict is enough
        self.follow_up_context_per_chat = {}  # Track follow-up context for each chat

    def _load_config(self):
        try:
            with open(self.config_file, "r") as f:
                return json.load(f)
        except:
            return {}

    def _save_config(self, config):
        with open(self.config_file, "w") as f:
            json.dump(config, f, indent=2)

    def _load_active_personality(self, config):
        pid = config.get("active_personality", "ai_assistant")
        try:
            with open(self.personalities_file, "r", encoding="utf-8-sig") as f:
                pers = json.load(f)
                return next((p for p in pers if p["id"] == pid), {})
        except Exception:
            return {}

    async def handle_chat_request(self, request: schemas.ChatRequest) -> Dict:
        logger.info(f"--- ORCHESTRATOR START: {request.provider} / {request.model} ---")
        
        # === 1. SETUP & VALIDATION ===
        if not request.chat_id: 
            raise HTTPException(400, "Missing chat_id")
            
        user_text = request.prompt or ""
        
        # Extract text from content list if present
        if request.content:
            for part in request.content:
                if part.type == "text":
                    user_text = part.text
                    break
        
        if not user_text:
            raise HTTPException(400, "Empty request")

        api_key = keyring.get_password("Janus-Projekt", request.provider)
        if not api_key:
            raise HTTPException(400, "API Key missing")

        # Speichere die User-Nachricht SOFORT. Das ist die Quelle der Wahrheit.
        crud.create_message(self.db, request.chat_id, "user", user_text)

        # Lade Kontext-Variablen früh, damit sie überall verfügbar sind
        config = self._load_config()
        persona = self._load_active_personality(config)
        email_context = self.last_email_list_per_chat.get(request.chat_id)

        # === 2. STATEFUL FOLLOW-UP CHECK (HÖCHSTE PRIORITÄT) ===
        follow_up_context = self.follow_up_context_per_chat.get(request.chat_id)
        is_confirmation = any(word in user_text.lower() for word in ["ja", "yes", "ok", "okay", "bestätige", "mach das"])

        if follow_up_context and is_confirmation:
            logger.info(f"✅ Follow-Up für Chat {request.chat_id} bestätigt. Führe aus: {follow_up_context['pending_tools']}")
            
            # Lösche Kontext SOFORT, um Doppel-Ausführung zu verhindern
            del self.follow_up_context_per_chat[request.chat_id]
            
            # Bereite die Ausführung vor
            tool_names_to_execute = follow_up_context['pending_tools']
            from backend.tool_registry import get_all_tool_definitions
            tools = [t for t in get_all_tool_definitions() if t['function']['name'] in tool_names_to_execute]
            
            # Baue den Kontext für diesen spezifischen Call (inkl. der neuen User-Nachricht)
            messages = self.context_builder.build_chat_history_for_execution(
                request.chat_id, 
                user_text, 
                persona, 
                email_context
            )
            
            executor = ToolExecutor(
                self.db, 
                api_key, 
                request.provider, 
                request.model,
                additional_context={
                    "last_ssml": self.last_ssml_response_per_chat.get(request.chat_id),
                    "email_context": email_context
                }
            )

            response = await llm_gateway.reason_and_respond(
                provider=request.provider, 
                model=request.model, 
                api_key=api_key,
                chat_history=messages, 
                context_manager=self.context_manager, 
                db=self.db,
                user_prompt=user_text, 
                chat_id=request.chat_id,
                tool_executor=executor, 
                tools_override=tools,
                disable_tools=intent_classifier.is_identity_query(user_text)
            )
            
            final_text = response.get("text", "Aktion wurde ausgeführt.")
            crud.create_message(self.db, request.chat_id, "model", final_text)
            return {"sender": "model", "text": final_text}

        # === 3. STANDARD "DIAMANTSTANDARD" ROUTING PIPELINE ===
        messages = self.context_builder.build_chat_history_for_execution(
            request.chat_id, 
            user_text, 
            persona, 
            email_context
        )
        system_prompt_content = messages[0]['content'] if messages and messages[0]['role'] == 'system' else ""

        # 3.1 Memory First Check
        if system_prompt_content:
            is_sufficient, direct_answer = self._check_if_memory_is_sufficient(system_prompt_content)
            if is_sufficient:
                logger.info("💎 Wissens-Kaskade: Direkte Antwort im Memory gefunden.")
                crud.create_message(self.db, request.chat_id, "model", direct_answer)
                return {"sender": "model", "text": direct_answer}
                
        # 3.2 Diamond Logic Pipeline
        # 1. Determine the correct planner model (using catalog IDs)
        if request.provider == "openai":
            planner_model = "gpt-5-nano"
        elif request.provider == "gemini":
            planner_model = "gemini-3-flash-preview"
        else:
            # Fallback to gpt-5-nano for unknown providers
            planner_model = "gpt-5-nano"
            logger.warning(f"Using fallback model {planner_model} for unknown provider: {request.provider}")

        logger.info(f"--- 🧠 STARTING DIAMOND LOGIC PIPELINE (Provider: {request.provider}, Model: {planner_model}) ---")
        
        try:
            # Get raw facts from memory
            raw_facts = memory_manager.get_relevant_facts_as_objects(self.db, user_text)
            
            # 3.2a Planner (Extraction & Scoring)
            # 2. Call the planner with the selected model
            decision_context = await generate_decision_context(
                user_query=user_text,
                retrieved_facts=raw_facts,
                api_key=api_key,
                provider=request.provider,
                model=planner_model  # Passes "gpt-5-nano" or "gemini-3-flash-preview"
            )
            
            # 3.2b Verifier (Integrity Check)
            decision_context = verify_decision_integrity(
                decision=decision_context,
                retrieved_facts=raw_facts
            )
            
            # Log the decision context status
            logger.info(f"Diamond Decision Status: {decision_context.status}")
            if decision_context.recommendations:
                logger.info(f"Top Recommendation: {decision_context.recommendations[0].candidate_name}")
                
            # If we have a clear decision, generate a response
            if decision_context.status == "ok" and decision_context.recommendations:
                # Build the final prompt with the decision context
                # --- FIX: Pydantic V2 Syntax ---
                system_prompt = f"""
                Du bist Janus. Deine Aufgabe ist es, das folgende Entscheidungsprotokoll in eine natürliche, hilfreiche Antwort zu übersetzen.
                
                PROTOKOLL:
                {decision_context.model_dump_json(indent=2, exclude_unset=True)}
                
                ANWEISUNG:
                - Sei präzise und fokussiere dich auf die wichtigsten Punkte.
                - Erwähne die wichtigsten Vor- und Nachteile.
                - Falls vorhanden, erwähne die zugrunde liegenden Beweise.
                - Sei natürlich und hilfreich im Ton.
                """
                
                # Update the messages with the new system prompt
                messages = [{"role": "system", "content": system_prompt.strip()}] + messages[1:]
                
                # Get the final response
                response = await llm_gateway.call_llm(
                    provider=request.provider,
                    model_id=request.model,
                    api_key=api_key,
                    messages=messages
                )
                
                final_text = response.get("text", "Ich konnte keine klare Empfehlung ableiten.")
                crud.create_message(self.db, request.chat_id, "model", final_text)
                
                # --- FIX: Start fact extraction also here ---
                self._trigger_fact_extraction(request.chat_id, user_text, final_text, api_key, request.provider)
                
                return {"sender": "model", "text": final_text}
                
        except Exception as e:
            logger.error(f"Fehler in der Diamond Logic Pipeline: {str(e)}", exc_info=True)
            # Fall through to standard flow if there's an error
        
        # 3.2 Candidate Retrieval
        candidates = ToolSelector.retrieve_candidates(user_text)
        top_score = max((c["confidence"] for c in candidates), default=0.0)

        # 3.3 Route B (Planner)
        if 0.5 <= top_score < 0.8:
            logger.info(f"💎 Routing: Route B (Planner) gewählt. Score: {top_score}")
            planner_prompt = self.context_builder.build_planner_prompt(candidates)
            planner_messages = [{"role": "system", "content": planner_prompt}] + messages
            
            planner_response = await llm_gateway.call_llm(
                provider=request.provider, 
                model_id=request.model, 
                api_key=api_key, 
                messages=planner_messages
            )
            
            self.follow_up_context_per_chat[request.chat_id] = {"pending_tools": [c["tool_name"] for c in candidates]}
            logger.info(f"📝 Follow-Up Context (Planner) für Chat {request.chat_id} gesetzt.")

            final_text = planner_response.get("text", "Ich bin unsicher, wie ich helfen soll.")
            crud.create_message(self.db, request.chat_id, "model", final_text)
            return {"sender": "model", "text": final_text}

        # 3.4 Route A (High Confidence & Safety)
        if top_score >= 0.8:
            logger.info(f"💎 Routing: Route A (High Confidence) gewählt. Score: {top_score}")
            high_conf_candidates = [c["tool_name"] for c in candidates if c["confidence"] >= 0.8]
            
            if any(ToolSelector.is_risky(t) for t in high_conf_candidates):
                logger.warning("🚨 Safety Guardrail: Kritisches Tool erkannt.")
                safety_prompt = self.context_builder.build_safety_prompt(high_conf_candidates)
                safety_messages = [{"role": "system", "content": safety_prompt}] + messages
                
                safety_response = await llm_gateway.call_llm(
                    provider=request.provider, 
                    model_id=request.model, 
                    api_key=api_key, 
                    messages=safety_messages
                )

                self.follow_up_context_per_chat[request.chat_id] = {
                    "pending_tools": high_conf_candidates, 
                    "requires_confirmation": True
                }
                logger.info(f"📝 Follow-Up Context (Safety) für Chat {request.chat_id} gesetzt.")
                
                final_text = safety_response.get("text", "Bitte bestätigen.")
                crud.create_message(self.db, request.chat_id, "model", final_text)
                return {"sender": "model", "text": final_text}

        # 3.5 Fallback to standard execution (Route A Focus or Route C)
        tools = ToolSelector.select_tools(user_text, email_context)
        if top_score >= 0.8:
            priority_names = {c["tool_name"] for c in candidates if c["confidence"] >= 0.8}
            priority_names.add("perform_websearch")
            tools = [t for t in tools if t['function']['name'] in priority_names]

        executor = ToolExecutor(
            self.db, 
            api_key, 
            request.provider, 
            request.model,
            additional_context={
                "last_ssml": self.last_ssml_response_per_chat.get(request.chat_id),
                "email_context": email_context
            }
        )
        
        response = await llm_gateway.reason_and_respond(
            provider=request.provider, 
            model=request.model, 
            api_key=api_key,
            chat_history=messages, 
            context_manager=self.context_manager, 
            db=self.db,
            user_prompt=user_text, 
            chat_id=request.chat_id,
            tool_executor=executor, 
            tools_override=tools,
            disable_tools=intent_classifier.is_identity_query(user_text)
        )
        
        final_text = response.get("text", "...")
        crud.create_message(self.db, request.chat_id, "model", final_text)
        
        # Update config with last used values
        config["last_used_provider"] = request.provider
        config["last_used_model"] = request.model
        self._save_config(config)
        
        # --- FIX: Standard Extraction Call (using helper) ---
        self._trigger_fact_extraction(request.chat_id, user_text, final_text, api_key, request.provider)
        
        return {"sender": "model", "text": final_text}

    def _trigger_fact_extraction(self, chat_id, user_text, final_text, api_key, provider):
        """Helper to trigger fact extraction background task safely."""
        if final_text and not intent_classifier.is_greeting(user_text):
            asyncio.create_task(self._run_fact_extraction(
                chat_id, user_text, final_text, api_key, provider
            ))

    def _check_if_memory_is_sufficient(self, system_prompt_content: str) -> (bool, str):
        """
        OPTIMIERTE HEURISTIK: Prüft, ob der Memory-Kontext eine direkte Antwort liefert.
        Ignoriert dabei Standard-Teile des Prompts wie den Zeit-Anker.
        """
        # Wir suchen nur im spezifischen Wissens-Kontext Block
        if "**WISSENS-KONTEXT:**" not in system_prompt_content:
            return False, ""

        # Extrahiere nur den relevanten Teil
        try:
            memory_section = system_prompt_content.split("**WISSENS-KONTEXT:**")[1]
        except IndexError:
            return False, ""

        lines = memory_section.split('\n')
        for line in lines:
            # Wir suchen nach Zeilen, die wie eine direkte Antwort aussehen
            # Beispiel: "- [Info] Deine Kundennummer ist KD-12345."
            line = line.strip()
            if line.startswith("-") and "[" in line and "]" in line and ":" in line:
                # Extrahiere den reinen Antworttext
                try:
                    answer = line.split(':', 1)[1].strip()
                    if answer: # Nur wenn nach dem : auch Text kommt
                        return True, answer
                except IndexError:
                    continue # Ignoriere Zeilen, die nicht dem Format entsprechen
        
        return False, ""

    async def _run_fact_extraction(self, chat_id, user, assistant, key, provider):
        """
        Startet die Fakten-Extraktion im Hintergrund.
        WICHTIG: Arbeitet autark mit dem Provider des aktuellen Chats.
        """
        try:
            # Wir wählen ein effizientes Modell passend zum Provider
            extraction_model = None
            
            if provider == "openai":
                extraction_model = "gpt-5-nano"
            elif provider == "gemini":
                # UPDATE: Nutzung von gemini-3-flash-preview für Faktenextraktion
                extraction_model = "gemini-3-flash-preview" 
            elif provider == "anthropic":
                extraction_model = "claude-3-haiku-20240307"
            elif provider == "groq":
                extraction_model = "llama3-8b-8192"
            else:
                # Fallback: Wenn kein Mapping existiert, brechen wir ab, statt zu raten.
                logger.warning(f"Fact extraction skipped: No dedicated extraction model mapping for provider '{provider}'.")
                return

            # Nur die Benutzernachricht an den Memory Extractor übergeben
            # um Redundanzen durch Neuformulierungen der KI zu vermeiden
            await memory_extractor.extract_and_save_fact(
                self.db, 
                chat_id, 
                user,  # Nur die Benutzernachricht übergeben
                key, 
                provider, 
                extraction_model
            )
        except Exception as e:
            logger.error(f"Fact extraction error: {e}")