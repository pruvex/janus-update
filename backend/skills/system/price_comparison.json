        "product_name": "string",
        "variant": "string",
        "price": "float",
        "currency": "string",
        "source": "string",
        "url": "string",
        "live_verified": "boolean"
      }
    ],
    "refurbished_tip": {
      "price": "float",
      "source": "string",
      "url": "string"
    },
    "metadata": {
