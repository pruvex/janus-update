          "count": 2
        },
        "error": null
      }
    },
    {
      "input": {
        "source": "unbekannt"
      },
      "output": {
        "status": "error",
        "data": null,
        "error": {
          "code": "INVALID_SOURCE",
          "message": "Unbekannte Quelle: unbekannt. Verfügbar: spiegel, gamestar, tagesschau, zeit, heise, reuters, bbc"
        }
      }
    }
  ]
}
