  "tags": [
    "system",
    "news",
    "rss",
    "media",
    "headlines"
  ],
  "capabilities": [
    "news_fetch",
    "web_read"
  ],
  "is_agent_ready": true,
  "deterministic_renderer": false,
  "max_calls_per_turn": 2,
  "depends_on": [],
  "examples": [
    {
      "input": {
        "source": "tagesschau",
        "query": null
      },
      "output": {
        "status": "ok",
        "data": {
          "headlines": ["Bundestag beschließt neues Klimagesetz", "DAX erreicht Rekordhoch"],
