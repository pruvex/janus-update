{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JanusLiveTestResult",
  "description": "Machine-readable aggregate result emitted by generated Janus Playwright live runners",
  "type": "object",
  "required": ["schemaVersion", "testRunId", "status", "summary", "artifacts", "results", "updatedAt"],
  "properties": {
    "schemaVersion": { "type": "string", "enum": ["janus.test-result.v1"] },
    "testRunId": { "type": "string", "pattern": "^TEST-RUN-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$" },
    "title": { "type": "string" },
    "status": { "type": "string", "enum": ["PASS", "FAIL", "PARTIAL", "BLOCKED", "RUNNING"] },
    "summary": {
      "type": "object",
      "required": ["total", "passed", "failed", "blocked", "manualGateRequired"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 },
        "manualGateRequired": { "type": "integer", "minimum": 0 }
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["resultDirectory", "resultJson", "evidenceFiles"],
      "properties": {
        "resultDirectory": { "type": "string" },
        "resultJson": { "type": "string" },
        "evidenceFiles": { "type": "array", "items": { "type": "string" } }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["testCaseId", "result", "classification", "evidencePath"],
        "properties": {
          "testCaseId": { "type": "string" },
          "result": { "type": "string" },
          "classification": { "type": "string" },
          "evidencePath": { "type": "string" },
          "durationMs": { "type": "integer", "minimum": 0 },
          "notes": { "type": "string" },
          "timestamp": { "type": "string" }
        }
      }
    },
    "updatedAt": { "type": "string" }
  }
}
