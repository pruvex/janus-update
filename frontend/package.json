{
  "name": "janus-frontend",
  "version": "1.0.0",
  "description": "Frontend for Janus",
  "main": "main.electron.js",
  "scripts": {
    "start": "concurrently \"npm:start-backend\" \"npm:start-frontend\"",
    "start-frontend": "electron .",
    "start-backend": "uvicorn --app-dir ../ backend.main:app --reload"
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "electron": "^28.0.0"
  }
}
