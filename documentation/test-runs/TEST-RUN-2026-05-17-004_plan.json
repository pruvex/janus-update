{
  "testRunId": "TEST-RUN-2026-05-17-004",
  "title": "Janus API Tool Routing",
  "executionMode": "LIVE_VISUAL",
  "target": "JANUS_CHAT",
  "chatWindow": "A",
  "baseUrl": "http://localhost:5173/",
  "backendHealthUrl": "http://localhost:8001/api/health",
  "timeouts": {
    "testCaseMs": 120000,
    "assistantResponseMs": 60000,
    "streamRequestMs": 15000
  },
  "strategies": {
    "send": "chat_button_click_send_v1",
    "wait": "assistant_stream_complete_v1",
    "evidence": "capture_network_v1",
    "evaluate": "contains_any_v1"
  },
  "tests": [
    {
      "id": "TC-001-GPT",
      "name": "Weather API routing",
      "type": "functional",
      "provider": "GPT",
      "model": "gpt-5.4-nano",
      "prompt": "Brauche ich morgen in Muenchen einen Regenschirm?",
      "expected": {
        "containsAny": [
          "Quelle:",
          "Wetterdienst",
          "Open-Meteo",
          "Wetterdaten laut",
          "Wetterdaten nach"
        ],
        "mustNotContain": [
          "Bankueberweisung",
          "unbegrenzt"
        ]
      }
    },
