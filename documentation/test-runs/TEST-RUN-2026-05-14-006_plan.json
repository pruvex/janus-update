      "name": "General capability question - Was kannst du?",
      "type": "functional",
      "provider": "GPT",
      "model": "gpt-5.4-nano",
      "prompt": "Was kannst du?",
      "expected": {
        "containsAny": ["Fähigkeit", "kann", "Hilfe", "Tools"],
        "mustNotContain": ["halluziniert", "erfunden"]
      }
    },
