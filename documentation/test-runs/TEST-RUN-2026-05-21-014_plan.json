      "id": "TC-001-GPT",
      "name": "Static registry check",
      "type": "functional",
      "provider": "GPT",
      "model": "gpt-5.4-nano",
      "prompt": "Validate capability registry references",
      "expected": {
        "containsAny": [
          "Quelle:",
          "Wetterdienst",
          "Open-Meteo",
          "Wetterdaten laut",
          "Wetterdaten nach"
        ],
        "mustNotContain": [
          "Bankueberweisung",
          "unbegrenzt"
        ]
      },
      "parallelSafe": true,
