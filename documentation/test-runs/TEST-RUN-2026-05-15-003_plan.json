      "name": "General capability question",
      "type": "functional",
      "provider": "GPT",
      "model": "gpt-5.4-nano",
      "prompt": "Was kannst du?",
      "expected": {
        "containsAny": [
          "Faehigkeiten",
          "verfuegbar",
          "Janus"
        ],
        "mustNotContain": [
          "Bankueberweisung",
          "unbegrenzt"
        ]
