{
  "name": "janus-projekt",
  "version": "1.1.0",
  "description": "",
  "type": "module",
  "main": "main.electron.cjs",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start-backend": "cross-env PYTHONIOENCODING=UTF-8 C:\\KI\\Janus-Projekt\\backend\\venv\\Scripts\\python.exe -m uvicorn backend.main:app --reload --port 8001 --host localhost",
    "start-frontend": "concurrently \"npm run start-electron\" \"npm run start-vite\"",
    "start-dev": "concurrently \"npm:start-backend\" \"npm:start-frontend\"",
    "start-electron": "wait-on tcp:8001 && cross-env NODE_ENV=development electron .",
    "start-electron-only": "cross-env NODE_ENV=development electron .",
    "start-vite": "vite",
    "start-backend-only": "cross-env PYTHONIOENCODING=UTF-8 C:\\KI\\Janus-Projekt\\backend\\venv\\Scripts\\python.exe -m uvicorn backend.main:app --reload --port 8001 --host localhost",
    "test:e2e": "playwright test",
    "build-installer": "electron-builder",
    "build-all": "npm run build && pyinstaller janus_backend.spec --clean --noconfirm && npm run build-installer"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.2",
    "electron-builder": "^26.0.12",
    "eslint": "^9.33.0",
    "vite": "^5.3.1",
    "wait-on": "^8.0.4"
  },
  "dependencies": {
    "axios": "^1.11.0"
  },
  "build": {
    "appId": "com.janus-projekt.app",
    "productName": "Janus Projekt",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "frontend/preload.js",
      "main.electron.js",
      "package.json"
    ],
          "extraResources": [
            {
              "from": "dist/janus_backend",
              "to": "dist/janus_backend",
              "filter": [
                "**/*"
              ]
            },
        {
          "from": "backend/personalities.json",
          "to": "dist/janus_backend/_internal/backend/personalities.json"
        },
        {
          "from": "backend/config.json",
          "to": "dist/janus_backend/_internal/backend/config.json"
        }          ],    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}