{
  "name": "janus-projekt",
  "version": "0.1.0-beta.9",
  "description": "",
  "type": "module",
  "main": "main.electron.cjs",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start-backend": "cross-env PYTHONIOENCODING=UTF-8 C:\\KI\\Janus-Projekt\\backend\\venv\\Scripts\\python.exe -m uvicorn backend.main:app --reload --port 8001 --host localhost",
    "start-frontend": "concurrently \"npm run start-electron\" \"npm run start-vite\"",
    "start-dev": "concurrently \"npm:start-backend-only\" \"npm:start-vite\" \"npm:start-electron\"",
    "start-electron": "wait-on tcp:8001 && cross-env NODE_ENV=development electron .",
    "start-electron-only": "cross-env NODE_ENV=development electron .",
    "start-vite": "vite frontend",
    "start-backend-only": "cross-env PYTHONIOENCODING=UTF-8 C:\\KI\\Janus-Projekt\\backend\\venv\\Scripts\\python.exe -m uvicorn backend.main:app --reload --port 8001 --host localhost",
    "start-backend-only-without-reload": "cross-env PYTHONIOENCODING=UTF-8 C:\\KI\\Janus-Projekt\\backend\\venv\\Scripts\\python.exe -m uvicorn backend.main:app --port 8001 --host localhost",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:log": "playwright test --reporter=list > test-log.md",
    "build-installer": "electron-builder",
    "build-all": "npm run build && python -m PyInstaller janus_backend.spec --clean --noconfirm && npm run build-installer"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.2",
    "electron-builder": "^26.0.12",
    "eslint": "^9.33.0",
    "vite": "^5.3.1",
    "wait-on": "^8.0.4"
  },
  "dependencies": {
    "axios": "^1.11.0"
  },
  "build": {
    "appId": "com.janus-projekt.app",
    "productName": "Janus Projekt",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "frontend/dist/**/*",
      "frontend/preload.js",
      "main.electron.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/janus_backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend/config",
        "to": "backend/backend/config"
      },
      {
        "from": "backend/static",
        "to": "backend/backend/static"
      },
      {
        "from": "backend/assets",
        "to": "backend/backend/assets"
      },
      {
        "from": "backend/bin",
        "to": "backend/backend/bin"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
