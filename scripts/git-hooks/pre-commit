#!/usr/bin/env bash
# Janus Git Pre-Commit Hook - delegiert an PowerShell (Windows-nativer Blocker-Check)
# Git-for-Windows fuehrt Hooks via sh.exe aus; pwsh/powershell ruft die eigentliche Logik.

HOOK_DIR="$(dirname "$0")"
PS_SCRIPT="$HOOK_DIR/pre-commit.ps1"

if [ ! -f "$PS_SCRIPT" ]; then
  echo "[PRE-COMMIT] Missing $PS_SCRIPT"
  exit 1
fi

# Bevorzuge pwsh (PS 7), Fallback powershell (PS 5.1)
if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "$PS_SCRIPT"
else
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$PS_SCRIPT"
fi
exit $?
